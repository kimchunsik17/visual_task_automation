# Database Connection (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
# If empty or not set, it will fallback to a local SQLite for testing if configured,
# or you must provide a valid postgres URL.
DATABASE_URL=sqlite:///./sql_app.db


# Gemini API Key for LangGraph nodes
GEMINI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# OpenAI API Key for ChatGPT models
OPENAI_API_KEY=

# Anthropic API Key for Claude models
ANTHROPIC_API_KEY=
