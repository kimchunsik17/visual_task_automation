# Database Connection (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
# If empty or not set, it will fallback to a local SQLite for testing if configured,
# or you must provide a valid postgres URL.
DATABASE_URL=postgresql://postgres:password@localhost/automation_db

# Gemini API Key for LangGraph nodes
GEMINI_API_KEY=your_gemini_api_key_here
